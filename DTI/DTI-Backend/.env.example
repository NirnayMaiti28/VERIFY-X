# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI model settings (passed through to the existing model)
NEWS_API_KEY=your_newsapi_key_here

# Verification timeout (seconds) — how long to wait for pipeline before 504
VERIFY_TIMEOUT_SECONDS=45

# Rate limiting
RATE_LIMIT=10/minute

# Verdict thresholds (passed to model)
VERDICT_TRUE_THRESHOLD=0.75
VERDICT_FALSE_THRESHOLD=0.25
VERDICT_UNVERIFIED_CAP=0.5
VERDICT_ABSTAIN_MIN_CONFIDENCE=0.3

# NHTM parameters
NHTM_BETA=1.0
NHTM_GAMMA=1.0
NHTM_LAMBDA=0.5
NHTM_DECAY_RATE=0.1
NHTM_PRIOR=0.5

# Retrieval
RETRIEVAL_TIME_BUDGET_SECONDS=20